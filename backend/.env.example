# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/datasite?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_characters_long_please_change_this
JWT_EXPIRE=30d

# Paystack
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxx

# CORS (comma-separated for multiple origins in production)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# DataBossHub API
# production
DATABOSSHUB_BASE_URL=https://www.databosshub.org/api/v1
DATABOSSHUB_API_KEY=your_databosshub_api_key_here
TOPZA_WEBHOOK_SECRET=