                        "type": "string",
                        "description": "Current day name in lowercase",
                        "example": "friday"
                      },
                      "currentSchedule": {
                        "type": "object",
                        "description": "Today's operating schedule",
                        "properties": {
                          "isOpen": {
                            "type": "boolean",
                            "description": "Whether the store is open today",
                            "example": true
                          },
                          "openTime": {
                            "type": "string",
                            "description": "Opening time in HH:MM format",
                            "example": "08:00"
                          },
                          "closeTime": {
                            "type": "string",
                            "description": "Closing time in HH:MM format",
                            "example": "18:00"
